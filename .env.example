# ============================================================================
# Hostal Coll — variables de entorno (plantilla). Copia a `.env` y rellena.
# NUNCA subir `.env` al repositorio (ver .gitignore).
# ============================================================================

# --- Base de datos (PostgreSQL) ---------------------------------------------
# Opción A · Postgres local (docker-compose): un único valor basta y DIRECT_URL
#   puede ser igual que DATABASE_URL.
#   DATABASE_URL="postgresql://hostalcoll:hostalcoll@localhost:5432/hostalcoll?schema=public"
#   DIRECT_URL="postgresql://hostalcoll:hostalcoll@localhost:5432/hostalcoll?schema=public"
#
# Opción B · Supabase (recomendada para Vercel/serverless):
#   DATABASE_URL = transaction pooler (puerto 6543) → runtime serverless.
#   DIRECT_URL   = conexión de sesión (puerto 5432) → migraciones.
#   Saca ambas de: Supabase → Connect (sustituye [YOUR-PASSWORD]).
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Autenticación (JWT) ----------------------------------------------------
# Secreto para firmar los JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="CAMBIA_ESTO_por_un_secreto_largo_y_aleatorio"
# Duración de la sesión (segundos). Por defecto 8 h.
JWT_TTL_SECONDS="28800"

# --- Cifrado de documentos de identidad (AES-256-GCM) -----------------------
# Clave de 32 bytes en base64. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠ Si se pierde esta clave, los documentos cifrados son irrecuperables.
DOCUMENT_ENCRYPTION_KEY="CAMBIA_ESTO_clave_de_32_bytes_en_base64"

# --- Almacenamiento de ficheros (adjuntos, documentos cifrados) -------------
# Local (desarrollo): disco bajo STORAGE_DIR.
STORAGE_DIR="./storage"
# Producción/Vercel: Supabase Storage (el disco de Vercel es efímero). Si estas
# dos están rellenas, se usa Supabase Storage en lugar del disco.
#   SUPABASE_URL: Supabase → Project Settings → API → Project URL.
#   SUPABASE_SERVICE_ROLE_KEY: misma pantalla → service_role (⚠ SECRETA).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="adjunts"

# --- Mossos d'Esquadra ------------------------------------------------------
# ⚠ §9: el `file_identifier` (9-10 car., en "Dades de l'establiment" del portal)
#   NO es el Id policial numérico (000000550). Pendiente de confirmar.
MOSSOS_FILE_IDENTIFIER=""
# Codificación del fitxer massiu — §9.3 (probablemente latin1). Configurable.
MOSSOS_ENCODING="latin1"
# Credenciales del portal para el conector Playwright (Fase 1, opcional).
# ⚠ NUNCA se loguean. En producción usar un secret manager, no .env.
MOSSOS_USER=""
MOSSOS_PASS=""

# --- AEAT Veri*Factu (enviament del registre de facturació) -----------------
# Certificat digital (.pfx/.p12) del obligat o representant per al TLS client.
# Si es deixa buit, l'enviament a l'AEAT queda inactiu (els registres es generen
# i s'encadenen igualment en local). El mode de proves del QR/endpoint es
# controla amb establiment.verifactuTestMode (a /config).
AEAT_CERT_PFX_PATH=""
AEAT_CERT_PASS=""

# --- App --------------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Hostal Coll"
