{
  "name": "hostalcoll-gestion",
  "version": "0.1.0",
  "private": true,
  "description": "PMS + ERP integral para Hostal Coll (Cataluña) — registro de viajeros (Mossos), CRM, facturación, gastos, activos, personal y analítica.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "build:next": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "mossos:upload": "tsx --conditions=react-server scripts/mossos-upload.ts",
    "user:hcoll": "tsx scripts/create-hcoll-user.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "esbuild"
    ]
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prisma": "^6.3.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
